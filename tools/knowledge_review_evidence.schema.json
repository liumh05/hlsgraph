          "pattern": "^[^\\u0000-\\u001F\\u007F]+$",
          "type": "string"
        },
        "version": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$",
          "type": "string"
